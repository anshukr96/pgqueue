# PostgreSQL connection URL
# Local Docker: postgresql://jobqueue:jobqueue_secret@localhost:5432/jobqueue_db
DATABASE_URL=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Application
PORT=3000
NODE_ENV=development

# Worker — WORKER_ID defaults to "worker-<pid>" if not set
WORKER_ID=worker-1
WORKER_CONCURRENCY=5
POLL_INTERVAL_MS=1000
